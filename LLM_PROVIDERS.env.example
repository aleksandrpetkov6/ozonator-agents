# LLM diversification for Екатерина (AS)
# -------------------------------------------------------
# Порядок fallback (слева направо). AS попробует каждого провайдера,
# у которого задан ключ, и переключится при ошибках/лимитах.
OZONATOR_LLM_PROVIDER_ORDER=groq,cerebras,openrouter,mistral,fireworks,openai

# -------------------------------------------------------
# 1) Groq (free tier)
GROQ_API_KEY=...
# (опционально) переопределить base/model
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
# (опционально) vision model
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# -------------------------------------------------------
# 2) Cerebras Inference (free tier)
CEREBRAS_API_KEY=...
CEREBRAS_API_BASE=https://api.cerebras.ai/v1
CEREBRAS_MODEL=gpt-oss-120b

# -------------------------------------------------------
# 3) OpenRouter (free plan + free models)
OPENROUTER_API_KEY=...
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# Можно оставить openrouter/free (бесплатный роутер) или указать конкретную модель.
OPENROUTER_MODEL=openrouter/free
# Рекомендуемые (но не обязательные) заголовки для OpenRouter:
OPENROUTER_REFERER=https://your-domain.example
OPENROUTER_APP_NAME=Ozonator Agents

# -------------------------------------------------------
# 4) Mistral (Experiment/free tier)
MISTRAL_API_KEY=...
MISTRAL_API_BASE=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest

# -------------------------------------------------------
# 5) Fireworks (есть free credits для старта)
FIREWORKS_API_KEY=...
FIREWORKS_API_BASE=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct

# -------------------------------------------------------
# (опционально) OpenAI / любой OpenAI-compatible через OPENAI_API_URL
OPENAI_API_KEY=...
# Может быть base (https://api.openai.com/v1) ИЛИ полный url на /chat/completions
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
